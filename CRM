async def procesar_mensaje(cliente_id: str, mensaje: str):
    """
    Procesa el mensaje con IA y guarda el resultado
    """
    # Calificar al lead
    analisis = calificar_lead(mensaje)
    
    # Guardar análisis en el perfil del cliente
    if cliente_id in clientes_db:
        clientes_db[cliente_id]["ultimo_analisis"] = analisis
        clientes_db[cliente_id]["lead_score"] = obtener_puntaje(analisis)
    
    # Si el lead es caliente, enviar notificación al dueño
    if analisis.get("Urgencia") == "Alta" and analisis.get("Intención") == "Compra":
        await notificar_lead_caliente(cliente_id, analisis)

def obtener_puntaje(analisis: dict) -> int:
    """Asigna un puntaje al lead basado en el análisis"""
    puntaje = 0
    if analisis.get("Urgencia") == "Alta":
        puntaje += 50
    if analisis.get("Intención") == "Compra":
        puntaje += 30
    if analisis.get("Presupuesto estimado") == "Alto":
        puntaje += 20
    return puntaje

