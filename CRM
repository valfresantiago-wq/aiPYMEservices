def consultar_productos_por_ia(query: str, session: Session) -> List[Producto]:
    """
    Usa IA para interpretar la pregunta del cliente y buscar productos.
    """
    prompt = f"""
    Eres un asistente de catálogo para una tienda. 
    El cliente pregunta: "{query}"
    
    Debes responder SOLO con un JSON válido que contenga:
    1. 'categoria': La categoría que busca (o null si no especifica).
    2. 'palabras_clave': Lista de palabras clave para buscar en nombre y descripción.
    3. 'precio_max': Precio máximo que sugiere (o null si no lo menciona).
    
    Ejemplo: Si el cliente dice "busco una mochila escolar barata", devuelve:
    {{"categoria": "mochilas", "palabras_clave": ["escolar", "barata"], "precio_max": null}}
    """
    
    try:
        response = openai.ChatCompletion.create(
            model="gpt-4",
            messages=[{"role": "user", "content": prompt}],
            temperature=0.3,
            response_format={"type": "json_object"}
        )
        data = json.loads(response.choices[0].message.content)
        
        # Construir la consulta SQL basada en el análisis de IA
        query_db = session.query(Producto).filter(Producto.activo == True)
        
        if data.get("categoria"):
            query_db = query_db.filter(Producto.categoria.ilike(f"%{data['categoria']}%"))
        
        if data.get("palabras_clave"):
            for palabra in data["palabras_clave"]:
                query_db = query_db.filter(
                    (Producto.nombre.ilike(f"%{palabra}%")) | 
                    (Producto.descripcion.ilike(f"%{palabra}%")) |
                    (Producto.etiquetas.ilike(f"%{palabra}%"))
                )
        
        if data.get("precio_max"):
            query_db = query_db.filter(Producto.precio <= float(data["precio_max"]))
        
        return query_db.limit(10).all()
    
    except Exception as e:
        # Fallback: búsqueda simple por nombre
        return session.query(Producto).filter(
            Producto.nombre.ilike(f"%{query}%") | 
            Producto.descripcion.ilike(f"%{query}%")
        ).limit(5).all()

def generar_respuesta_con_productos(productos: List[Producto], query: str) -> str:
    """
    Genera una respuesta amigable con los productos encontrados.
    """
    if not productos:
        return f"Lo siento, no encontré productos que coincidan con '{query}'. ¿Podés ser más específico?"
    
    prompt = f"""
    El cliente preguntó: "{query}"
    
    Estos son los productos que encontré en el catálogo:
    {json.dumps([{"nombre": p.nombre, "precio": p.precio, "stock": p.stock} for p in productos], indent=2)}
    
    Genera una respuesta amigable, profesional y breve (máximo 3 oraciones) que:
    1. Mencione los productos encontrados con sus precios.
    2. Si algún producto tiene poco stock, avisa.
    3. Ofrece ayuda para más detalles.
    """
    
    try:
        response = openai.ChatCompletion.create(
            model="gpt-4",
            messages=[{"role": "user", "content": prompt}],
            temperature=0.7,
            max_tokens=200
        )
        return response.choices[0].message.content
    except:
        # Fallback
        respuesta = "Encontré estos productos:\n"
        for p in productos:
            respuesta += f"- {p.nombre}: ${p.precio} ({p.stock} unidades disponibles)\n"
        return respuesta

