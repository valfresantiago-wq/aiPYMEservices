def calificar_lead(mensaje: str) -> dict:
    """Usa IA para analizar el mensaje y calificar al lead"""
    prompt = f"""
    Eres un asistente de ventas. Analiza este mensaje de un cliente:
    "{mensaje}"
    
    Responde en JSON con:
    1. Intención (Compra, Consulta, Reclamo, Spam)
    2. Urgencia (Alta, Media, Baja)
    3. Presupuesto estimado (Bajo, Medio, Alto)
    4. Producto o servicio que busca (texto libre)
    """
    
    response = openai.ChatCompletion.create(
        model="gpt-4",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.3
    )
    
    return json.loads(response.choices[0].message.content)

